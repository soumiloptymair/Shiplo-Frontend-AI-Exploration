{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Angular: Dev server",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building|Compiling",
          "endsPattern": "Application bundle generation complete|Compiled successfully|Local:"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "GitHub: Auto-sync (background)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/github-auto-sync.sh",
      "isBackground": true,
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "GitHub: Pull now",
      "type": "shell",
      "command": "git pull --ff-only",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "GitHub: Push now",
      "type": "shell",
      "command": "git push -u origin HEAD",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "GitHub: Sync (pull then push)",
      "type": "shell",
      "command": "git pull --ff-only && git push -u origin HEAD",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
